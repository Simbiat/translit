{
    "name": "simbiat/translit",
    "type": "library",
    "keywords": [
        "php",
        "romanization",
        "transliteration"
    ],
    "description": "Class to transliterate lots of characters",
    "homepage": "https://github.com/Simbiat/translit",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Dmitrii Kustov",
            "email": "support@simbiat.dev",
            "homepage": "https://www.simbiat.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-intl": "*"
    },
    "replace": {
        "simbiat/filename-sanitizer": "*"
    },
    "autoload": {
        "psr-4": {
            "Simbiat\\Translit\\": "src/"
        }
    },
    "support": {
        "issues": "https://github.com/Simbiat/translit/issues",
        "source": "https://github.com/Simbiat/translit"
    }
