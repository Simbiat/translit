{
    "name": "simbiat/stringhelper",
    "type": "library",
    "keywords": [
        "php",
        "romanization",
        "transliteration",
        "strings",
        "sanitization"
    ],
    "description": "Various helpers for working with strings",
    "homepage": "https://github.com/Simbiat/StringHelper",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Dmitrii Kustov",
            "email": "support@simbiat.eu",
            "homepage": "https://www.simbiat.eu",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-intl": "*",
        "ext-mbstring": "*"
    },
    "replace": {
        "simbiat/filename-sanitizer": "*",
        "simbiat/translit": "*"
    },
    "autoload": {
        "psr-4": {
            "Simbiat\\StringHelper\\": "src/"
        }
    },
    "support": {
        "issues": "https://github.com/Simbiat/StringHelper/issues",
        "source": "https://github.com/Simbiat/StringHelper"
